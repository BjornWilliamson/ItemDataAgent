# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Postmark Configuration
# Get your Server API Token from https://account.postmarkapp.com/
POSTMARK_API_TOKEN=your_postmark_server_token_here
POSTMARK_FROM_EMAIL=your-sender@yourdomain.com

# Email Inbox Polling (for receiving replies)
# Your webmail IMAP settings
IMAP_SERVER=imap.one.com
IMAP_PORT=993
IMAP_USERNAME=your-email@yourdomain.com
IMAP_PASSWORD=your-email-password
IMAP_USE_SSL=true

# ERP API Configuration
ERP_API_BASE_URL=https://your-erp-system.com/api
ERP_API_KEY=your_erp_api_key_here

# Application Configuration
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Database (SQLite for conversation tracking)
DATABASE_PATH=./agent_data.db
